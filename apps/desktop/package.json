{
  "name": "@share-clipboard/desktop",
  "version": "1.0.0",
  "description": "Share Clipboard - Electron Desktop Application",
  "main": "./out/main/index.js",
  "author": "share-clipboard",
  "homepage": "https://github.com/share-clipboard",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run db:generate && npm run typecheck:node && npm run typecheck:web",
    "start": "node scripts/run-electron-vite.mjs preview",
    "dev": "pnpm run db:generate && node scripts/run-electron-vite.mjs dev",
    "build": "pnpm run db:generate && npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "pnpm run db:generate && electron-vite build && electron-builder --mac",
    "build:linux": "pnpm run db:generate && electron-vite build && electron-builder --linux",
    "clean": "rm -rf out dist node_modules .turbo"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@share-clipboard/i18n": "workspace:*",
    "@share-clipboard/ui": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@uiw/react-markdown-preview": "^5.2.0",
    "@uiw/react-md-editor": "^4.1.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.3.9",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.16.0",
    "better-sqlite3": "^12.4.7",
    "marked": "^18.0.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.15.0",
    "remark-breaks": "^4.0.0",
    "shiki": "^4.0.2",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "dotenv": "^16.5.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@share-clipboard/eslint-config": "workspace:*",
    "@share-clipboard/tsconfig": "workspace:*",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "resolve": "^1.22.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
